{
  "settingsInheritedFrom": "amsclark/mend-settings@main",
  "checkRunSettings": {
    "vulnerableCheckRunConclusionLevel": "failure",
    "displayMode": "diff",
    "useMendCheckNames": true
  },
  "issueSettings": {
    "minSeverityLevel": "LOW",
    "issueType": "DEPENDENCY"
  },
  "scanSettings": {
    "baseBranches": ["main", "master"]
  }
}
